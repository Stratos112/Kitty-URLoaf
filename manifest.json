{
  "manifest_version": 2,
  "name": "Kitty URLoaf",
  "version": "0.1.0",
  "description": "",
  "browser_specific_settings": {
    "gecko": {
      "id": "urloaf@kitty",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "static/plus.svg",
    "48": "static/plus.svg",
    "128": "static/plus.svg"
  },
  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": "static/plus.svg"
  },
  "background": {
    "scripts": ["src/background/background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"]
    }
  ],
  "permissions": ["storage"],
  "web_accessible_resources": [
    "static/plus-red.svg",
    "static/plus-orange.svg",
    "static/plus-yellow.svg",
    "static/plus-green.svg",
    "static/plus-cyan.svg",
    "static/plus-blue.svg",
    "static/plus-purple.svg",
    "static/plus-pink.svg"
  ]
}
